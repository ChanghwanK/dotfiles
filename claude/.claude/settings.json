{
  "cleanupPeriodDays": 30,
  "env": {
    "ENABLE_TOOL_SEARCH": "auto:5",
    "CLAUDE_CODE_NO_FLICKER": "1",
    "CLAUDE_MEM_MODE": "code--ko",
    "CLAUDE_CODE_ENABLE_DESIGN_MCP": "1"
  },
  "permissions": {
    "allow": [
      "Bash(kubectl config use-context:*)",
      "Bash($HOME/.claude/scripts/notify-slack.sh *)"
    ],
    "defaultMode": "auto"
  },
  "model": "sonnet",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/scripts/detect-future-todo.py",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/alfred-session-start.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cmd=$(cat | python3 -c \"import sys,json; d=json.load(sys.stdin); print(d.get('tool_input',{}).get('command',''))\"); if printf '%s' \"$cmd\" | grep -qE 'kubectl[[:space:]]+(edit|delete)'; then printf 'BLOCKED: kubectl edit/delete bypasses GitOps and will be reverted by ArgoCD. Modify YAML files in Git instead.\\n' >&2; exit 2; fi"
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/plan-preview.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/notify-plan-done.sh"
          }
        ]
      },
      {
        "matcher": "mcp__claude_ai_Notion__notion-create-pages",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/scripts/notion-review-reminder.py"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/scripts/notion-review-reminder.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/notify-on-stop.sh"
          },
          {
            "type": "command",
            "command": "$HOME/.claude/scripts/plan-text-preview.sh"
          }
        ]
      }
    ]
  },
  "worktree": {
    "baseRef": "fresh"
  },
  "statusLine": {
    "type": "command",
    "command": "python3 $HOME/.claude/statusline.py"
  },
  "enabledPlugins": {
    "claude-mem@thedotmack": true
  },
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "editorMode": "vim",
  "skipAutoPermissionPrompt": true
}
